# ============================================================
# errflow-dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env to version control.
# ============================================================

# ------------------------------------------------------------------
# Backend API
# Production example: https://api.yourdomain.com/api
# ------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ------------------------------------------------------------------
# NextAuth.js
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# NEXTAUTH_URL must match the canonical URL of this app (no trailing slash)
# ------------------------------------------------------------------
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32-output
NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------------------------------
# GitHub OAuth (for user login)
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL to register: ${NEXTAUTH_URL}/api/auth/callback/github
# ------------------------------------------------------------------
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
