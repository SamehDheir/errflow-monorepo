# ============================================================
# api-errflow — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# Database (PostgreSQL / Neon)
# For Neon: use the *pooled* connection string for DATABASE_URL
#           and the *direct* string for DIRECT_DATABASE_URL (migrations)
# ------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require&pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require"

# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------
PORT=3001
FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------------
# JWT
# Generate secrets with: openssl rand -hex 64
# Access token: short-lived (15m); Refresh token: long-lived (7d)
# ------------------------------------------------------------------
JWT_SECRET=replace-with-64-hex-chars-openssl-rand-hex-64
JWT_REFRESH_SECRET=replace-with-a-different-64-hex-chars-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------------------------------
# Encryption
# Used to encrypt GitHub OAuth tokens at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32   (produces exactly 64 hex chars)
# CRITICAL: back this up securely — losing it makes stored tokens unrecoverable.
# ------------------------------------------------------------------
ENCRYPTION_KEY=replace-with-64-hex-chars-openssl-rand-hex-32

# ------------------------------------------------------------------
# AI (Groq)
# Get your key at https://console.groq.com/keys
# ------------------------------------------------------------------
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ------------------------------------------------------------------
# Redis
# For local dev use HOST/PORT. For cloud (Upstash etc.) use REDIS_URL.
# REDIS_URL takes precedence if set.
# ------------------------------------------------------------------
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------------------------------------------------------------------
# Email — Resend (transactional email)
# Get your key at https://resend.com/api-keys
# Verify your sending domain at https://resend.com/domains
# ------------------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ------------------------------------------------------------------
# Email — Gmail SMTP (optional fallback)
# Use an App Password, not your account password.
# Generate at: https://myaccount.google.com/apppasswords
# ------------------------------------------------------------------
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ------------------------------------------------------------------
# GitHub App (for opening PRs)
# Create at: https://github.com/settings/apps
# ------------------------------------------------------------------
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-private-key-here\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# ------------------------------------------------------------------
# GitHub OAuth (for user login)
# Create at: https://github.com/settings/developers → OAuth Apps
# ------------------------------------------------------------------
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret
